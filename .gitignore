__pycache__/
*.pyc

# Playwright MCP scratch output (snapshots, screenshots)
.playwright-mcp/
phase-*.png
test-*.png
screenshot-*.png

# Skill artifacts (outputs from running bundled skills — belong in
# ~/.openhive/artifacts, not the repo). Keep SKILL.md, scripts, lib,
# helpers, reference, templates; ignore generated files at the skill root.
packages/skills/*/*.pdf
packages/skills/*/*.pdf.spec.json
packages/skills/*/*.docx
packages/skills/*/*.pptx
packages/skills/**/__pycache__/
packages/skills/**/*.pyc

# Claude Code working state (worktrees, lock files) is per-machine
.claude/

# Docs are local-only
docs/

# Claude Code project instructions are local-only
CLAUDE.md
