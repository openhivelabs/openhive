{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-server",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "noEmit": false,
    "incremental": false,
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true,
    "allowJs": false,
    "plugins": [],
    "jsx": "preserve",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "server/**/*.ts",
    "lib/server/**/*.ts",
    "instrumentation-node.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "app/**",
    "src/**",
    "components/**",
    "dist/**",
    "dist-server/**",
    "node_modules/**"
  ]
}
