{
  "name": "openhive",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @openhive/web dev",
    "build": "pnpm --filter @openhive/web build",
    "start": "pnpm --filter @openhive/web start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fonts:fetch": "python3 packages/skills/_lib/fonts.py",
    "fonts:fetch:all": "python3 packages/skills/_lib/fonts.py --all"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  }
}
